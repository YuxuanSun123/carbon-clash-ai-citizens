# AI API 配置
# 请复制此文件为 .env 并根据你的部署方式填入配置

# 方式1: 使用DeepSeek官方API
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
VITE_DEEPSEEK_MODEL=deepseek-chat

# 方式2: 使用Ollama本地部署
# VITE_DEEPSEEK_API_URL=http://localhost:11434/v1/chat/completions
# VITE_DEEPSEEK_MODEL=deepseek-r1:1.5b
# VITE_DEEPSEEK_API_KEY=  # ollama不需要API key，留空即可

# 获取DeepSeek官方API密钥的步骤：
# 1. 访问 https://platform.deepseek.com/
# 2. 注册账号并登录
# 3. 在控制台中创建API密钥
# 4. 将密钥复制到上面的配置中

# 使用Ollama本地部署的步骤：
# 1. 安装Ollama: https://ollama.ai/
# 2. 下载DeepSeek模型: ollama pull deepseek-r1:1.5b
# 3. 启动Ollama服务: ollama serve
# 4. 使用上面的Ollama配置